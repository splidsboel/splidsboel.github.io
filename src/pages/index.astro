---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="space-y-6">
    <h1 class="text-4xl font-bold tracking-tight text-zinc-900">
      Hi, I'm Jakob 👋
    </h1>
    <p class="text-lg leading-relaxed">
      Welcome to my personal corner of the web. This is where I'll collect
      projects, writing, and whatever else I feel like sharing.
    </p>
    <p class="leading-relaxed">
      Add a new page by dropping a file in <code
        class="rounded bg-zinc-100 px-1.5 py-0.5 text-sm">src/pages/</code
      > and adding a link in <code
        class="rounded bg-zinc-100 px-1.5 py-0.5 text-sm">src/config.ts</code
      >.
    </p>
  </section>
</Layout>
