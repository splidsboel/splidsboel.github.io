---
import Layout from '../layouts/Layout.astro';
import { PROJECTS } from '../config';

const isExternal = (href: string) => /^https?:\/\//.test(href);
---

<Layout title="Projects" description="Things Jakob Splidsboel has built.">
  <section class="space-y-8">
    <h1 class="text-3xl font-bold tracking-tight text-zinc-900">Projects</h1>

    <ul class="space-y-8">
      {
        PROJECTS.map((project) => (
          <li class="border-b border-zinc-100 pb-8 last:border-0">
            <div class="flex items-baseline justify-between gap-4">
              <h2 class="text-lg font-semibold text-zinc-900">
                <a
                  href={project.href}
                  class="hover:underline"
                  {...(isExternal(project.href)
                    ? { target: '_blank', rel: 'noopener' }
                    : {})}
                >
                  {project.title}
                </a>
              </h2>
              {project.year && (
                <span class="shrink-0 text-sm text-zinc-400">{project.year}</span>
              )}
            </div>

            <p class="mt-2 leading-relaxed">{project.description}</p>

            {project.tags && project.tags.length > 0 && (
              <ul class="mt-3 flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <li class="rounded-full bg-zinc-100 px-2.5 py-0.5 text-xs text-zinc-500">
                    {tag}
                  </li>
                ))}
              </ul>
            )}

            <div class="mt-3 flex gap-4 text-sm">
              {project.href && (
                <a
                  href={project.href}
                  class="text-zinc-900 underline underline-offset-4 hover:no-underline"
                  {...(isExternal(project.href)
                    ? { target: '_blank', rel: 'noopener' }
                    : {})}
                >
                  {isExternal(project.href) ? 'Visit →' : 'Open →'}
                </a>
              )}
              {project.repo && (
                <a
                  href={project.repo}
                  target="_blank"
                  rel="noopener"
                  class="text-zinc-500 underline underline-offset-4 hover:text-zinc-900"
                >
                  Source
                </a>
              )}
              {project.report && (
                <a
                  href={project.report}
                  {...(isExternal(project.report)
                    ? { target: '_blank', rel: 'noopener' }
                    : { target: '_blank' })}
                  class="text-zinc-500 underline underline-offset-4 hover:text-zinc-900"
                >
                  Report
                </a>
              )}
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
